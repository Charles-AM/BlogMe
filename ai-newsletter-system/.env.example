APP_BASE_URL=http://localhost:8000
DATABASE_URL=./newsletter.db

# Free source APIs. The app runs with RSS-only fallback if these are omitted.
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-newsletter-system/1.0 by your_reddit_username
WELT_API_BASE_URL=
WELT_API_KEY=

# Free AI tier.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Gmail API. See README for creating token.json.
GMAIL_SENDER=
GMAIL_TOKEN_JSON=./token.json
GMAIL_CREDENTIALS_JSON=./credentials.json

# Runtime controls.
NEWSAPI_DAILY_LIMIT=100
MIN_SCORE=7.0
MAX_ARTICLES_PER_USER=8
